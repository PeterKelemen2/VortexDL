# =============================================================================
# ytdlp_client — backend environment reference
# Copy this file to `.env` and adjust values for your deployment.
#   cp .env.example .env
# =============================================================================

# --- Application -------------------------------------------------------------
APP_NAME="Downloader API"
# Enable verbose/debug behaviour. Keep "false" in production.
DEBUG=false

# --- Database ----------------------------------------------------------------
# Async SQLAlchemy URL. Alembic derives its sync URL by stripping "+aiosqlite".
# Local dev (file in CWD):
SQLALCHEMY_DATABASE_URI=sqlite+aiosqlite:///./app.db
# Docker compose uses a persisted volume path instead:
#   SQLALCHEMY_DATABASE_URI=sqlite+aiosqlite:////app/data/app.db

# --- JWT / authentication ----------------------------------------------------
# REQUIRED. Must be a cryptographically random string of at least 32 chars.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ISSUER=ytdlp_client
JWT_AUDIENCE=ytdlp_client
JWT_ALGORITHM=HS256

# Refresh-token cookie SameSite policy: lax | strict | none
# Use "none" only behind HTTPS when frontend/backend are on different origins.
COOKIE_SAMESITE=lax

# --- Initial admin bootstrap -------------------------------------------------
# When all three are set, an admin user is created on first startup.
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
# If true, elevate an existing user with the above email/username to admin.
ADMIN_BOOTSTRAP_FORCE_ELEVATE_EXISTING=false

# --- CORS / frontend ---------------------------------------------------------
# Comma-separated list of allowed browser origins for the API.
CORS_ORIGINS=http://localhost:5173
# Public base URL of the frontend, used to build links in outgoing emails.
FRONTEND_URL=http://localhost:5173

# --- Profile image uploads ---------------------------------------------------
PROFILE_IMAGE_UPLOAD_DIR=./uploads
PROFILE_IMAGE_UPLOAD_SUBDIR=profile_images
PROFILE_IMAGE_URL_PATH=/uploads
PROFILE_IMAGE_MAX_SIZE_MB=5
PROFILE_IMAGE_VARIANT_AVATAR_SIZE=120
PROFILE_IMAGE_VARIANT_THUMBNAIL_SIZE=200
PROFILE_IMAGE_VARIANT_PREVIEW_SIZE=420
PROFILE_IMAGE_VARIANT_QUALITY=85
PROFILE_IMAGE_VARIANT_SEPARATOR=__

# --- SMTP / email delivery ---------------------------------------------------
# Leave SMTP_HOST unset to run in "console" mode: emails are logged instead of
# sent (useful for local development). Set these to enable real delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Use STARTTLS (typical for port 587).
SMTP_USE_TLS=true
# Use implicit TLS/SSL (typical for port 465). Mutually exclusive with USE_TLS.
SMTP_USE_SSL=false
SMTP_TIMEOUT=10
EMAIL_FROM=no-reply@localhost
EMAIL_FROM_NAME="Downloader API"

# --- Email verification / password reset -------------------------------------
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
# When true, newly registered users must verify their email before logging in.
REQUIRE_EMAIL_VERIFICATION=false

# --- Rate limiting -----------------------------------------------------------
# Disable globally with RATE_LIMIT_ENABLED=false (tests set this automatically).
RATE_LIMIT_ENABLED=true
# slowapi limit syntax: "<count>/<period>" e.g. 5/minute, 30/minute, 5/hour.
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_REFRESH=30/minute
RATE_LIMIT_PASSWORD_RESET=5/hour
RATE_LIMIT_EMAIL_VERIFICATION=5/hour

# --- Background job queue ----------------------------------------------------
# Number of concurrent in-process worker tasks processing the job queue.
JOB_WORKER_CONCURRENCY=2
# Root directory where yt-dlp writes downloads (per-user subdirectories).
DOWNLOAD_DIR=./downloads
